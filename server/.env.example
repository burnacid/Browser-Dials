# Copy this file to .env and fill in your values

# Server
PORT=3737

# MySQL / MariaDB connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=browser_dials
DB_PASS=changeme
DB_NAME=browser_dials

# Initial API key — copy this value into the extension options page.
# You can create additional keys via the api_keys table directly.
API_KEY=replace-with-a-long-random-secret

# Default sync user created on startup if missing.
SYNC_DEFAULT_USERNAME=admin
SYNC_DEFAULT_PASSWORD=change-me-now
